/**
 * Memory of 8 registers, each 16 bit-wide. Out holds the value
 * stored at the memory location specified by address. If load==1, then 
 * the in value is loaded into the memory location specified by address 
 * (the loaded value will be emitted to out from the next time step onward).
 */

CHIP RAM8 {
    IN in[16], load, address[3];
    OUT out[16];

	PARTS:
	Not(in=load, out=nload);
	Not(in=address[0], out=ns0);
	Not(in=address[1], out=ns1);
	Not(in=address[2], out=ns2);

    // Распределяем load по 8 регистрах в зависимости от address
	
	Nand (a=load, b=address[2], out=out01);
	Nand (a=load, b=out01, out=out02);
	Not (in=out01, out=x);
	Not (in=out02, out=y);

	Nand (a = y, b = address[1], out = out1);
	Nand (a = y, b = out1, out = out2);
	Not (in = out1, out = out3);
	Not (in = out2, out = out4);
	Nand (a = out3, b = address[0], out = out5);
	Nand (a = out4, b = address[0], out = out6);
	Nand (a = out4, b = out6, out = out7);
	Nand (a = out3, b = out5, out = out8);
	Not (in = out7, out = load0);
	Not (in = out6, out = load1);
	Not (in = out8, out = load2);
	Not (in = out5, out = load3);

	Nand (a = x, b = address[1], out = out1t);
	Nand (a = x, b = out1t, out = out2t);
	Not (in = out1t, out = out3t);
	Not (in = out2t, out = out4t);
	Nand (a = out3t, b = address[0], out = out5t);
	Nand (a = out4t, b = address[0], out = out6t);
	Nand (a = out4t, b = out6t, out = out7t);
	Nand (a = out3t, b = out5t, out = out8t);
	Not (in = out7t, out = load4);
	Not (in = out6t, out = load5);
	Not (in = out8t, out = load6);
	Not (in = out5t, out = load7);
//-------------------------------

	Not(in=load0, out=nload0);
	Not(in=load1, out=nload1);
	Not(in=load2, out=nload2);
	Not(in=load3, out=nload3);
	Not(in=load4, out=nload4);
	Not(in=load5, out=nload5);
	Not(in=load6, out=nload6);
	Not(in=load7, out=nload7);	

        Nand(a=in[0],  b=load0,  out=in0load0);
        Nand(a=dffout0X0, b=nload0, out=out0X0nload0);
        Nand(a=in0load0,   b=out0X0nload0,  out=in0load0out0X0nload0);
        DFF(in=in0load0out0X0nload0, out = dffout0X0, out=out0X0);
        
        Nand(a=in[1],  b=load0,  out=in1load0);
        Nand(a=dffout0X1, b=nload0, out=out0X1nload0);
        Nand(a=in1load0,   b=out0X1nload0,  out=in1load0out0X1nload0);
        DFF(in=in1load0out0X1nload0, out = dffout0X1, out=out0X1);
        
        Nand(a=in[2],  b=load0,  out=in2load0);
        Nand(a=dffout0X2, b=nload0, out=out0X2nload0);
        Nand(a=in2load0,   b=out0X2nload0,  out=in2load0out0X2nload0);
        DFF(in=in2load0out0X2nload0, out = dffout0X2, out=out0X2);
        
        Nand(a=in[3],  b=load0,  out=in3load0);
        Nand(a=dffout0X3, b=nload0, out=out0X3nload0);
        Nand(a=in3load0,   b=out0X3nload0,  out=in3load0out0X3nload0);
        DFF(in=in3load0out0X3nload0, out = dffout0X3, out=out0X3);
        
        Nand(a=in[4],  b=load0,  out=in4load0);
        Nand(a=dffout0X4, b=nload0, out=out0X4nload0);
        Nand(a=in4load0,   b=out0X4nload0,  out=in4load0out0X4nload0);
        DFF(in=in4load0out0X4nload0, out = dffout0X4, out=out0X4);
        
        Nand(a=in[5],  b=load0,  out=in5load0);
        Nand(a=dffout0X5, b=nload0, out=out0X5nload0);
        Nand(a=in5load0,   b=out0X5nload0,  out=in5load0out0X5nload0);
        DFF(in=in5load0out0X5nload0, out = dffout0X5, out=out0X5);
        
        Nand(a=in[6],  b=load0,  out=in6load0);
        Nand(a=dffout0X6, b=nload0, out=out0X6nload0);
        Nand(a=in6load0,   b=out0X6nload0,  out=in6load0out0X6nload0);
        DFF(in=in6load0out0X6nload0, out = dffout0X6, out=out0X6);
        
        Nand(a=in[7],  b=load0,  out=in7load0);
        Nand(a=dffout0X7, b=nload0, out=out0X7nload0);
        Nand(a=in7load0,   b=out0X7nload0,  out=in7load0out0X7nload0);
        DFF(in=in7load0out0X7nload0, out = dffout0X7, out=out0X7);
        
        Nand(a=in[8],  b=load0,  out=in8load0);
        Nand(a=dffout0X8, b=nload0, out=out0X8nload0);
        Nand(a=in8load0,   b=out0X8nload0,  out=in8load0out0X8nload0);
        DFF(in=in8load0out0X8nload0, out = dffout0X8, out=out0X8);
        
        Nand(a=in[9],  b=load0,  out=in9load0);
        Nand(a=dffout0X9, b=nload0, out=out0X9nload0);
        Nand(a=in9load0,   b=out0X9nload0,  out=in9load0out0X9nload0);
        DFF(in=in9load0out0X9nload0, out = dffout0X9, out=out0X9);
        
        Nand(a=in[10],  b=load0,  out=in10load0);
        Nand(a=dffout0X10, b=nload0, out=out0X10nload0);
        Nand(a=in10load0,   b=out0X10nload0,  out=in10load0out0X10nload0);
        DFF(in=in10load0out0X10nload0, out = dffout0X10, out=out0X10);
        
        Nand(a=in[11],  b=load0,  out=in11load0);
        Nand(a=dffout0X11, b=nload0, out=out0X11nload0);
        Nand(a=in11load0,   b=out0X11nload0,  out=in11load0out0X11nload0);
