        DFF(in=in15load0out0X15nload0, out = dffout0X15, out=out0X15);
        
        Nand(a=in[0],  b=load1,  out=in0load1);
        Nand(a=dffout1X0, b=nload1, out=out1X0nload1);
        Nand(a=in0load1,   b=out1X0nload1,  out=in0load1out1X0nload1);
        DFF(in=in0load1out1X0nload1, out = dffout1X0, out=out1X0);
        
        Nand(a=in[1],  b=load1,  out=in1load1);
        Nand(a=dffout1X1, b=nload1, out=out1X1nload1);
        Nand(a=in1load1,   b=out1X1nload1,  out=in1load1out1X1nload1);
        DFF(in=in1load1out1X1nload1, out = dffout1X1, out=out1X1);
        
        Nand(a=in[2],  b=load1,  out=in2load1);
        Nand(a=dffout1X2, b=nload1, out=out1X2nload1);
        Nand(a=in2load1,   b=out1X2nload1,  out=in2load1out1X2nload1);
