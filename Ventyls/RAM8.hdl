        DFF(in=in9load1out1X9nload1, out = dffout1X9, out=out1X9);
        
        Nand(a=in[10],  b=load1,  out=in10load1);
        Nand(a=dffout1X10, b=nload1, out=out1X10nload1);
        Nand(a=in10load1,   b=out1X10nload1,  out=in10load1out1X10nload1);
        DFF(in=in10load1out1X10nload1, out = dffout1X10, out=out1X10);
        
        Nand(a=in[11],  b=load1,  out=in11load1);
        Nand(a=dffout1X11, b=nload1, out=out1X11nload1);
        Nand(a=in11load1,   b=out1X11nload1,  out=in11load1out1X11nload1);
        DFF(in=in11load1out1X11nload1, out = dffout1X11, out=out1X11);
        
        Nand(a=in[12],  b=load1,  out=in12load1);
        Nand(a=dffout1X12, b=nload1, out=out1X12nload1);
        Nand(a=in12load1,   b=out1X12nload1,  out=in12load1out1X12nload1);
        DFF(in=in12load1out1X12nload1, out = dffout1X12, out=out1X12);
        
        Nand(a=in[13],  b=load1,  out=in13load1);
        Nand(a=dffout1X13, b=nload1, out=out1X13nload1);
        Nand(a=in13load1,   b=out1X13nload1,  out=in13load1out1X13nload1);
        DFF(in=in13load1out1X13nload1, out = dffout1X13, out=out1X13);
        
        Nand(a=in[14],  b=load1,  out=in14load1);
        Nand(a=dffout1X14, b=nload1, out=out1X14nload1);
        Nand(a=in14load1,   b=out1X14nload1,  out=in14load1out1X14nload1);
