        Nand(a=in15load1,   b=out1X15nload1,  out=in15load1out1X15nload1);
        DFF(in=in15load1out1X15nload1, out = dffout1X15, out=out1X15);
        
        Nand(a=in[0],  b=load2,  out=in0load2);
